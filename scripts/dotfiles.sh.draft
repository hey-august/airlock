# djakafljasdklfj
cp airlock/config.fish /airlock/.config/fish/config.fish

# tmux
mkdir .config/tmux/
dev@work ~> cp airlock/.config/tmux/tmux.conf /airlock/.config/tmux/

# tmux plugin manager
git clone https://github.com/tmux-plugins/tpm ~/.config/tmux/plugins/tpm

# git
mkdir git
cp airlock/.config/git/config.example /airlock/.config/git/config

# install claude
curl -fsSL https://claude.ai/install.sh | bash

# install sudo, grant permissions to main user
apt update && apt install -y sudo
usermod -aG sudo dev
